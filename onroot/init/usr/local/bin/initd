#!/usr/bin/env bash
COMPOSITOR=$1
PROFILE=$2
DOTFILES_DIR="$HOME/.dotfiles"

if [ -d "$DOTFILES_DIR/profiles" ]; then
	cd "$DOTFILES_DIR/profiles/" || exit
	for dir in *; do
		cd "$dir" || exit
		stow -D -t ~ * 2>/dev/null
		cd ..
	done
fi

if [ -d "$DOTFILES_DIR/shared" ]; then
    shopt -s nullglob
    shared_pkgs=("$DOTFILES_DIR/shared/"*)
    if [ ${#shared_pkgs[@]} -gt 0 ]; then
        cd "$DOTFILES_DIR/shared/" || exit
        stow --no-folding -t ~ *
    fi
fi

if [[ -n "$PROFILE" && -d "$DOTFILES_DIR/profiles/$PROFILE" ]]; then
	cd "$DOTFILES_DIR/profiles/$PROFILE" || exit
	for pkg in */; do
		pkg_name="${pkg%/}"
		stow -d "$DOTFILES_DIR/shared/" -D -t ~ "$pkg_name" 2>/dev/null
		rm -rf "$HOME/.config/$pkg"
	done
	stow --no-folding --override=".*" -t ~ *
fi

cd "$HOME" || exit
exec "$COMPOSITOR"
