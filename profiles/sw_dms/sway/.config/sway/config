set $mod Mod4

#exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term kitty
# Your preferred application launcher
set $menu wmenu-run


# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:monospace 11
#font pango:JetBrainsMono Nerd Font 11
#font pango:Victor Mono 11
#font pango:Rajdhani SemiBold 11

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8


#System autostarts
include start.conf

#Keybindings
include keybinds/keybinds.conf

#Bar it's noctalia now
#include bar/bar.conf

#Border
include border/border.conf

#Gaps
include gaps/gaps.conf

#Wallpaper
include wallpaper.conf
#output eDP-1 bg ~/Pictures/Wallpapers/rezeroramandrom.jpg stretch



# libinput configuation
input "type:touchpad" {
		tap	enabled
		drag enabled
		drag_lock disabled
		middle_emulation enabled
    natural_scroll enabled
    dwt enabled
		#events disabled_on_external_mouse
    accel_profile "flat" # disable mouse acceleration (enabled by default; to set it manually, use "adaptive" instead of "flat")
    pointer_accel 0.6
		scroll_factor 0.8
}

input "type:keyboard" {
		xkb_options caps:escape
		#xkb_options caps:swapescape
}


# lid on off when closing the lid on off, on off wtf
set $laptop eDP-1
bindswitch --reload --locked lid:on output $laptop disable
bindswitch --reload --locked lid:off output $laptop enable



output * adaptive_sync off


include ~/.config/sway/noctalia
